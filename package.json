{
  "name": "to-local",
  "version": "0.0.1-alpha.0",
  "private": true,
  "description": "Privacy-first Chrome extension for on-demand web timestamp conversion.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "postinstall": "wxt prepare",
    "test:e2e": "TOLOCAL_E2E=1 wxt build && playwright test",
    "test:permissions": "wxt build && node tests/manual/permission-flow.mjs",
    "typecheck": "wxt prepare && tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:bundle": "node scripts/check-bundle.mjs",
    "check:contrast": "node scripts/check-contrast.mjs",
    "icons": "node scripts/render-icons.mjs",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm check:contrast && pnpm build && pnpm check:bundle"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.31",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.3",
    "prettier": "^3.8.4",
    "selfsigned": "^5.5.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.4",
    "wxt": "^0.20.26"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
